# Copy this file to /www/wwwroot/excelcc/kick-deploy/deploy.env on the server.
# Keep the real deploy.env out of git if it contains private values.

REPO_URL="https://github.com/Laowang3366/kick.git"
BRANCH="codex/admin-ai-assistant-management"
REPO_DIR="/www/wwwroot/excelcc/kick-deploy/repo"

WEB_RUNTIME_DIR="/www/wwwroot/excelcc/kick-web"
BACKEND_RUNTIME_DIR="/www/wwwroot/excelcc/kick-backend"
BACKEND_SERVICE="kick-backend.service"

DEPLOY_USER="www"
DEPLOY_GROUP="www"

# 1 = fetch/pull the configured branch before building.
# 0 = build whatever code is already checked out in REPO_DIR.
GIT_PULL_BEFORE_BUILD="1"
GIT_REMOTE="origin"

# Optional overrides:
# HEALTH_ENDPOINT="http://127.0.0.1:8081/api/public/home-overview"
# BACKUP_ROOT="/www/wwwroot/excelcc/kick-deploy/backups"
# HEALTH_RETRY_COUNT="24"
# HEALTH_RETRY_DELAY="5"
