# Copy selected values into /www/wwwroot/kick-backend/.env.production.
# Keep real credentials and host-specific secrets out of git.
#
# LAN sizing target: homeserver, 12 CPU, about 16 GB RAM, MySQL in Docker.
# These values are conservative starting points; validate with load tests and
# MySQL connection capacity before increasing them.

# JVM flags are only effective when kick-backend.service ExecStart consumes
# JAVA_OPTS, for example:
#   ExecStart=/bin/sh -c 'exec java $JAVA_OPTS -jar /www/wwwroot/kick-backend/forum-1.0.0.jar'
JAVA_OPTS="-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/www/wwwroot/kick-backend/heapdump.hprof -XX:+ExitOnOutOfMemoryError -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai"

# Embedded Tomcat.
SERVER_TOMCAT_THREADS_MAX=240
SERVER_TOMCAT_THREADS_MIN_SPARE=24
SERVER_TOMCAT_MAX_CONNECTIONS=8192
SERVER_TOMCAT_ACCEPT_COUNT=1000
SERVER_TOMCAT_CONNECTION_TIMEOUT=10s

# HikariCP. Keep DB_POOL_MAX_SIZE below the MySQL server/container max
# connection budget after reserving capacity for admin and migration sessions.
DB_POOL_MAX_SIZE=30
DB_POOL_MIN_IDLE=10
DB_POOL_CONNECTION_TIMEOUT=3000
DB_POOL_VALIDATION_TIMEOUT=2000
DB_POOL_MAX_LIFETIME=1800000

# Redis latency budget. Leave at 1s for local Redis; raise only if Redis is
# remote or known to have occasional network jitter.
REDIS_TIMEOUT=1s
REDIS_CONNECT_TIMEOUT=1s

# Existing application secrets and connection strings belong in the real file.
# DB_URL=
# DB_USERNAME=
# DB_PASSWORD=
# JWT_SECRET=
